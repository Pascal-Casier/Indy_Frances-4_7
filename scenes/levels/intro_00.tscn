theme_override_fonts/font = SubResource("SystemFont_t7ne2")
theme_override_font_sizes/font_size = 22
text = "Você estava preocupado. 
Seu avô havia desaparecido há algumas semanas, 
e ninguém sabia onde ele estava. 
Sentindo-se perdido e querendo encontrar alguma pista, 
você decidiu explorar o sótão da casa do seu avô, um lugar cheio de lembranças e objetos antigos.

Enquanto mexia em uma velha caixa de madeira,
 você encontrou um envelope envelhecido com seu nome escrito à mão. 
Curioso, você abriu o envelope e encontrou a mensagem misteriosa de seu avô."
horizontal_alignment = 1
autowrap_mode = 2
text_overrun_behavior = 2

