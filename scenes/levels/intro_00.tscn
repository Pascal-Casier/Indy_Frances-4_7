[node name="Into00" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_67tvn")
paragraph1 = "Era uma noite  quente de verão. 

O céu, pintado de laranja e violeta, deixava passar 

os últimos raios de sol entre as árvores altas da floresta. "
paragraph2 = "Um caminho de terra serpenteava entre os arbustos até chegar 

a uma velha casa de madeira, escondida entre as sombras 

e os sons suaves da natureza."
paragraph3 = "Ali chegava Léo, vestido de aventureiro e com o olhar curioso. 
Fazia meses que não via o avô 
Desde que a escola acabou, Léo sonhava com este momento: 
passar as férias na casa do avô, longe da cidade, das aulas… 
e talvez descobrir um ou dois segredos esquecidos.

Entre sombras e folhas, ele se aproxima... Vamos segui-lo, só por um instante."
audios = Array[AudioStream]([ExtResource("2_5f18n"), ExtResource("3_icqb3"), ExtResource("4_18og4")])

