[node name="Panneau_affiche14" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(2, 0, 1.43646e-06, 0, 2, 0, -1.43646e-06, 0, 2, 45.7514, 11.0092, -155.778)
son = ExtResource("20_gblhl")
text1 = "Le son [wa] (oi)

Son : [wa] – comme “moi”, “trois”.
[color=#2E8B57]Som: [wa] – como “eu”, “três”.[/color]

Prononciation : commence par un son proche de [o], puis glisse vers [a].
[color=#2E8B57]Pronúncia: começa com um som próximo de [o] e desliza para [a].[/color]"
text2 = "[center]
Exemples :

moi /mwa/ – [color=#2E8B57]eu[/color]

toi /twa/ – [color=#2E8B57]você[/color]

trois /tʁwa/ – [color=#2E8B57]três[/color]
[/center]"

[node name="Panneau_affiche15" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(2, 0, 1.43646e-06, 0, 2, 0, -1.43646e-06, 0, 2, 55.7514, 11.0092, -155.778)
son = ExtResource("21_ad2j2")
text1 = "Le son [aj] (ai / ay / aï)

Son : [aj] – comme “travail”, “paille”.
[color=#2E8B57]Som: [aj] – como “trabalho”, “palha”.[/color]

Prononciation : commence par [a] puis glisse vers un [j] (son de “i”).
[color=#2E8B57]Pronúncia: começa com [a] e desliza para [j] (som de “i”).[/color]"
text2 = "[center]
Exemples :

travail /tʁavaj/ – [color=#2E8B57]trabalho[/color]

paille /paj/ – [color=#2E8B57]palha[/color]

taille /taj/ – [color=#2E8B57]tamanho[/color]
[/center]"

[node name="Panneau_affiche18" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(2, 0, 1.43646e-06, 0, 2, 0, -1.43646e-06, 0, 2, 65.7514, 11.0092, -155.778)
son = ExtResource("22_qfcmt")
text1 = "Le son [ij] / [j] (ill)

(selon le contexte)

Son : [ij] ou [j] – comme “fille”, “famille”.
[color=#2E8B57]Som: [ij] ou [j] – como “menina”, “família”.[/color]

Prononciation : souvent, “ill” se prononce comme une semi-voyelle [j].
[color=#2E8B57]Pronúncia: muitas vezes, “ill” se pronuncia como a semivogal [j].[/color]"
text2 = "[center]
fille /fij/ – [color=#2E8B57]menina[/color]

famille /famij/ – [color=#2E8B57]família[/color]

briller /bʁije/ – [color=#2E8B57]brilhar[/color]
[/center]"

[node name="Panneau_affiche16" parent="affiches2" instance=ExtResource("5_tp444")]
