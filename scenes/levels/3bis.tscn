son = ExtResource("23_f7veu")
text1 = "Le son [ɛj] (ei / ey / ail parfois)

Son : [ɛj] – comme “oreille”, “seize”.
[color=#2E8B57]Som: [ɛj] – como “orelha”, “dezesseis”.[/color]

Prononciation : commence par le son ouvert [ɛ], puis glisse vers [j].
[color=#2E8B57]Pronúncia: começa com o som aberto [ɛ] e desliza para [j].[/color]"
text2 = "[center]
Exemples :

oreille /ɔʁɛj/ – [color=#2E8B57]orelha[/color]

seize /sɛz/ – [color=#2E8B57]dezesseis[/color]

