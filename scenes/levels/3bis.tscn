[node name="Panneau_affiche" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(1.58151e-06, 0, -2, 0, 2, 0, 2, 0, 1.58151e-06, 37.7514, 4.00462, -27.2326)
son = ExtResource("6_x1h1c")
text1 = "Le son [ə] (e muet)

Son : [ə] – très faible, parfois presque silencieux.
[color=#2E8B57]Som: [ə] – muito fraco, às vezes quase silencioso.[/color]

Prononciation : les lèvres sont détendues, le son est rapide.
[color=#2E8B57]Pronúncia: os lábios ficam soltos, o som é rápido.[/color]"
text2 = "[center]
Exemples :

le /lə/ – [color=#2E8B57]o/a[/color]

je /jə/ – [color=#2E8B57]o[/color]

petite /pətit/ – [color=#2E8B57]pequena[/color]

[/center]"

[node name="Panneau_affiche7" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(-1.75636e-06, 0, 2, 0, 2, 0, -2, 0, -1.75636e-06, -38.2486, 4.00462, -97.2326)
son = ExtResource("13_0j76k")
text1 = "Le son [u]

Son : [u] – comme “loup”, “pouce”.
[color=#2E8B57]Som: [u] – como “lobo”, “polegar”.[/color]

Prononciation : lèvres très arrondies et projetées vers l’avant.
[color=#2E8B57]Pronúncia: lábios bem arredondados e projetados para frente.[/color]"
text2 = "[center]
Exemples :

loup /lu/ – [color=#2E8B57]lobo[/color]

roue /ʁu/ – [color=#2E8B57]roda[/color]

pouce /pus/ – [color=#2E8B57]polegar[/color]
[/center]"

[node name="Panneau_affiche8" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(1.73205, 0, 1, 0, 2, 0, -1, 0, 1.73205, -33.2486, 7.00462, -164.233)
son = ExtResource("14_i6ndu")
text1 = "Le son [y] (u français)

Son : [y] – très difficile pour les lusophones !
[color=#2E8B57]Som: [y] – muito difícil para os lusófonos![/color]

Prononciation : comme le [u] français mais avec la langue en position de [i].
[color=#2E8B57]Pronúncia: como o som [u] francês, mas com a língua na posição de [i].[/color]"
text2 = "[center]
Exemples :

lune /lyn/ – [color=#2E8B57]lua[/color]

lumière /lymjɛʁ/ – [color=#2E8B57]luz[/color]

musique /myzik/ – [color=#2E8B57]música[/color]
[/center]"

[node name="Panneau_affiche9" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(1.69873e-06, 0, -2, 0, 2, 0, 2, 0, 1.69873e-06, 13.7514, 5.00923, -164.233)
son = ExtResource("15_q60su")
text1 = "Le son [o]

Son : [o] – fermé, comme “eau”, “mot”.
[color=#2E8B57]Som: [o] – fechado, como “água”, “palavra”.[/color]

Prononciation : lèvres arrondies mais plus fermées que pour [ɔ].
[color=#2E8B57]Pronúncia: lábios arredondados, mas mais fechados que para [ɔ].[/color]"
text2 = "[center]
Exemples :

eau /o/ – [color=#2E8B57]água[/color]

mot /mo/ – [color=#2E8B57]palavra[/color]

chaud /ʃo/ – [color=#2E8B57]quente[/color]
[/center]"

[node name="Panneau_affiche10" parent="affiches2" instance=ExtResource("5_tp444")]
transform = Transform3D(-2, 0, -1.61131e-06, 0, 2, 0, 1.61131e-06, 0, -2, 19.7514, 9.00923, -118.233)
son = ExtResource("16_ki12r")
text1 = "Le son [ɔ]

Son : [ɔ] – ouvert, comme “porte”, “fort”.
[color=#2E8B57]Som: [ɔ] – aberto, como “porta”, “forte”.[/color]

Prononciation : bouche plus ouverte que pour [o], lèvres arrondies.
[color=#2E8B57]Pronúncia: boca mais aberta do que no som [o], lábios arredondados.[/color]"
text2 = "[center]
Exemples :

porte /pɔʁt/ – [color=#2E8B57]porta[/color]

