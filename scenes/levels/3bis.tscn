son = ExtResource("19_o4pvh")
text1 = "Le son [ɛ̃] (in / ain / un)

Son nasal [ɛ̃] – comme “pain”, “vin”.
[color=#2E8B57]Som nasal [ɛ̃] – como “pão”, “vinho”.[/color]

Prononciation : bouche semi-ouverte, air par le nez.
[color=#2E8B57]Pronúncia: boca semiaberta, ar pelo nariz.[/color]"
text2 = "[center]
Exemples :

pain /pɛ̃/ – [color=#2E8B57]pão[/color]

vin /vɛ̃/ – [color=#2E8B57]vinho[/color]

lundi /lœ̃di/ – [color=#2E8B57]segunda-feira[/color]
