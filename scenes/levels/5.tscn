[node name="Panneau_affiche" parent="World" instance=ExtResource("59_qlojj")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -35, 1.68784, -24)
son = null
text1 = "[color=#5A2D0C]Les verbes en -ER sont les verbes les plus fréquents en français.
On les appelle les verbes du 1er groupe (sauf aller, qui est irrégulier).[/color]
[color=#9932CC]Os verbos terminados em -ER são os mais frequentes em francês.
Eles são chamados de verbos do primeiro grupo (exceto [color=red]aller[/color], que é irregular).[/color]


Les lèvres restent étirées, comme pour sourire.
[color=#9932CC]Os lábios ficam esticados, como se estivesse sorrindo.[/color]
"
text2 = "✅ Étape 1 — Trouver le radical
[color=#9932CC] etapa 1 - encontrar o radical[/color]
On enlève -ER de l’infinitif.
[color=#9932CC] a gente tira -ER do infinitivo.[/color]

parl[color=#FF0000]er[/color] → parl-
mang[color=#FF0000]er[/color] → mang-
aim[color=#FF0000]er[/color] → aim-"

[node name="Panneau_affiche2" parent="World" instance=ExtResource("59_qlojj")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -47.4472, 3.68784, -24.7109)
son = ExtResource("60_8d1bk")
text1 = "✅ Étape 2 — Ajouter les terminaisons
[color=#9932CC]Passo 2 — Adicione as terminações[/color]

[color=red]-e, -es, -e, -ons, -ez, -ent[/color]

"
text2 = "✅ Exemple complet

Aimer (amar, gostar)

j’aim[color=#FF0000]e[/color]
tu aim[color=#FF0000]es[/color]
il aim[color=#FF0000]e[/color]
nous aim[color=#FF0000]ons[/color]
vous aim[color=#FF0000]ez[/color]
ils aim[color=#FF0000]ent[/color]"

[node name="Panneau_affiche3" parent="World" instance=ExtResource("59_qlojj")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -60.4472, 1.25887, -24.7109)
son = ExtResource("61_oe8bl")
text1 = "⚠️ Attention à la prononciation. [color=purple]⚠️ Preste atenção à pronúncia[/color]

👉 parle, parles, parlent se prononcent pareil.
[color=purple]parle, parles, parlent são pronunciados da mesma forma.[/color]
"
text2 = "🎯 Verbes très courants en -ER

parler (falar)
aimer (gostar, amar)
travailler (trabalhar)
regarder (olhar)
jouer (jogar, brincar)
habiter (morar)"

