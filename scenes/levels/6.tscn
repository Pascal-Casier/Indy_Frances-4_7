[node name="Panneau_affiche" parent="Panneaux" instance=ExtResource("33_ug3xx")]
son = ExtResource("25_pg7dg")
text1 = "[center][b][u]LES NOMBRES EN FRANÇAIS (0–20)[/u][/b][/center]

[b]1. Les nombres de 0 à 10[/b]

0 = zéro [zé-ro]  
1 = un [ã]  
2 = deux [dø]  
3 = trois [troa]  
4 = quatre [katr]  
5 = cinq [sank]  
6 = six [sis]  
7 = sept [sèt]  
8 = huit [uit]  
9 = neuf [nœf]  
10 = dix [dis]  "
text2 = "[b]2. Les nombres de 11 à 20[/b]

11 = onze [onz]  
12 = douze [duz]  
13 = treize [trèz]  
14 = quatorze [katɔrz]  
15 = quinze [kɛ̃z]  
16 = seize [sèz]  
17 = dix-sept [dis-sèt]  
18 = dix-huit [diz-uit]  
19 = dix-neuf [diz-nœf]  
20 = vingt [vã]  "

[node name="Panneau_affiche2" parent="Panneaux" instance=ExtResource("33_ug3xx")]
transform = Transform3D(-4.37114e-08, 0, 1, 0, 1, 0, -1, 0, -4.37114e-08, -8, 6, 50)
son = ExtResource("26_hnwg2")
text1 = "[b][u]1. Les dizaines principales[/u][/b]

20 = vingt [vã]  
30 = trente [trãt]  
40 = quarante [karãt]  
50 = cinquante [sankãt]  
60 = soixante [soassãt]  "
text2 = "[b][u]2. Comment former les nombres ?[/u][/b]

On combine : dizaine + nombre  

21 = vingt et un [vãt é ã]  
22 = vingt-deux [vãt dø]  
23 = vingt-trois [vãt troa]  

31 = trente et un [trãt é ã]  
32 = trente-deux [trãt dø]  

[b][u]⚠️ Important :[/u][/b]
• On utilise [color=red]et[/color] seulement avec [color=red]1[/color]  
→ 21, 31, 41, 51, 61  

• Pas de [color=red]\"et\"[/color] avec les autres nombres  
→ 22, 23, 24..."

[node name="Panneau_affiche3" parent="Panneaux" instance=ExtResource("33_ug3xx")]
transform = Transform3D(1, 0, -1.58932e-08, 0, 1, 0, 1.58932e-08, 0, 1, -11, 12, 78)
son = ExtResource("38_kbcye")
text1 = "[b][u]1. Les nombres de 70 à 79[/u][/b]

⚠️ En français, on  utilise [b]60 + 10[/b]

70 = soixante-dix [soassã dis]  
71 = soixante et onze [soassã é onz]  
72 = soixante-douze [soassã duz]  
73 = soixante-treize [soassã trèz]  
74 = soixante-quatorze [soassã katɔrz]  
75 = soixante-quinze [soassã kɛ̃z]  
76 = soixante-seize [soassã sèz]  
77 = soixante-dix-sept [soassã dis-sèt]  
78 = soixante-dix-huit [soassã diz-uit]  
79 = soixante-dix-neuf [soassã diz-nœf]  "
text2 = "[b][u]2. Les nombres de 80 à 89[/u][/b]

⚠️ 80 = 4 × 20

80 = quatre-vingts [katrə-vã]  
81 = quatre-vingt-un [katrə-vã ã]  
82 = quatre-vingt-deux [katrə-vã dø]  
83 = quatre-vingt-trois [katrə-vã troa]  
...
89 = quatre-vingt-neuf [katrə-vã nœf]  

[b]3. Les nombres de 90 à 99[/b]

⚠️ 90 = 80 + 10

90 = quatre-vingt-dix [katrə-vã dis]  
91 = quatre-vingt-onze [katrə-vã onz]  
92 = quatre-vingt-douze [katrə-vã duz]  
...
98 = quatre-vingt-dix-huit [katrə-vã diz-uit]  
99 = quatre-vingt-dix-neuf [katrə-vã diz-nœf]  "

