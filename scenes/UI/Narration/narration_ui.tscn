[node name="Narration_UI" type="CanvasLayer"]
process_mode = 2
script = ExtResource("1_pbf24")
lines = PackedStringArray("Il était une fois...\n\n[color=green] Era uma vez...[/color]", "un jeune garçon\nappelé Leo\n\n[color=green]Um jovem rapaz\nchamado Leo[/color]\n", "Un jour, il reçoit\nune lettre de son grand-père Henri...\n\n[color=green]Um dia, ele recebe uma carta \nde seu avô Henri...[/color]", "\"Mon cher Léo, je  suis parti explorer \nune cité perdue dans la jungle.\n\n[color=green]\"Meu querido Leo, fui explorar\numa cidade perdida na selva.[/color]", "Un mystère m’a retenu ici. Suis mes indices, \napprends le français, et viens me sauver ! \n Henri\"\n\n[color=green]Um mistério me prendeu aqui. Siga minhas pistas, aprenda francês e venha me salvar!\nHenri\"[/color]", "Leo décide de se rendre chez son \ngrand-père pour résoudre ce mystère,...\n\n[color=green]Leo decide ir à casa do avô para resolver esse mistério...[/color]")
audio_lines = Array[AudioStream]([ExtResource("2_bfi6n"), ExtResource("3_mydwh"), ExtResource("4_plxht"), ExtResource("5_n64l0"), ExtResource("6_4y6iu"), ExtResource("7_bfi6n")])

